generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// NextAuth.js required models
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Core app models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  // Encrypted JSON: { provider: "openai"|"anthropic"|"google", apiKey: string }
  llmPreference String?   @db.Text
  // Deprecated: was used for Apollo/Clay API keys
  dbPreferences String?   @db.Text
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Project {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String?
  websiteUrl     String
  // JSON: scraped + AI-extracted company profile
  companyProfile Json?
  // JSON: { questions: ClarifyingQuestion[], answers: string[] }
  clarifyingQs   Json?
  // "b2b_saas" | "agency" | "services" | "other"
  businessType   String?
  status         ProjectStatus @default(RESEARCHING)
  // Unique token for public sharing — null means not shared
  shareToken     String?       @unique
  steps          ProjectStep[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
}

enum ProjectStatus {
  RESEARCHING
  CLARIFYING
  IN_PROGRESS
  COMPLETE
  ERROR
}

model ProjectStep {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stepName    StepName
  status      StepStatus @default(PENDING)
  // Typed JSON output for each step
  output      Json?
  draftOutput Json?
  // Error details
  errorCode   String?
  errorMsg    String?
  // Token usage from LLM call
  tokenUsage  Json?
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime   @updatedAt
  versions    ProjectStepVersion[] @relation("ProjectStepVersions")

  @@unique([projectId, stepName])
  @@index([projectId])
}

enum StepName {
  RESEARCH
  TARGET_MARKETS
  INDUSTRY_PRIORITY
  ICP
  SEGMENTATION
  MARKET_SIZING   // Deprecated — kept for DB compatibility
  COMPETITIVE
  POSITIONING     // Deprecated — kept for DB compatibility
  MANIFESTO
}

enum StepStatus {
  PENDING
  RUNNING
  AWAITING_APPROVAL
  COMPLETE
  ERROR
}

model ProjectStepVersion {
  id          String      @id @default(cuid())
  projectId   String
  stepName    StepName
  versionNum  Int
  output      Json
  prompt      String?
  createdAt   DateTime    @default(now())
  step        ProjectStep @relation("ProjectStepVersions", fields: [projectId, stepName], references: [projectId, stepName], onDelete: Cascade)

  @@index([projectId, stepName])
}
